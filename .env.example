# App role: full DML on the 3 loan tables
DATABASE_URL=postgresql+psycopg2://loan_app:loan_app_pw@localhost:5432/loan_db

# Read-only role: SELECT only, used by /sql endpoint
READONLY_DATABASE_URL=postgresql+psycopg2://loan_reader:loan_reader_pw@localhost:5432/loan_db

# MCP server uses this to reach the FastAPI service
API_BASE_URL=http://localhost:8000

# Set to "true" to expose POST /sql/write (off by default)
ALLOW_SQL_WRITES=false

# Anthropic API key for the embedded chat panel (server-side only; never exposed to browser)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini API key (optional — enables the Gemini provider toggle in the UI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Cerebras API key (optional — very generous free tier, fast inference)
# Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b

# Directory (inside the container) where uploaded files are mounted for ingest_from_path
UPLOADS_DIR=/uploads
